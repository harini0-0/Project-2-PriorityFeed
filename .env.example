# Copy this file to .env and fill in your real values. Never commit .env.

# MongoDB Atlas connection string (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=priorityfeed

# Slack token (xoxb- bot token or xoxp- user token)
SLACK_TOKEN=xoxb-your-token-here

# Secret used to sign login tokens (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Server
PORT=3000
